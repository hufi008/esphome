{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Save All Files",
      "type": "shell",
      "command": "${command:workbench.action.files.saveAll}"
    },
    {
      "label": "ESPHome RUN Mainfile OTA",
      "type": "shell",
      "command": "esphome run ${config:esphome.mainfile} --device OTA --no-states",
      "group": {"kind": "build", "isDefault": true},
      
      // 1. Zwingt VS Code, die Abhängigkeiten nacheinander (sequentiell) abzuarbeiten
      "dependsOrder": "sequence",
      "dependsOn": [
        "Save All Files"
      ],
      
      "presentation": {
        "reveal": "always",
        // 2. Nutzt ein fest zugeordnetes Panel für diese Task
        "panel": "dedicated",
        // 3. Löscht den alten Text im Terminal vor dem Neustart
        "clear": true,
        // 4. Verhindert die nervige "Terminal will be reused" Meldung
        "showReuseMessage": false
      }
    }
  ]
}
